    "cloudinary": "^1.41.3",
    "clsx": "^2.1.1",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.546.0",
    "mongoose": "^8.9.0",
    "motion": "^12.23.24",
    "multer": "^1.4.5-lts.1",
